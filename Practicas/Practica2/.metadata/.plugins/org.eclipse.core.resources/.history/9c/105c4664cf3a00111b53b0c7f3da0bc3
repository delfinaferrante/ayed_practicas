package ej1;

public class TransformacionEj6 {
	BinaryTree<Integer> arbol;
	
	public TransformacionEj6(BinaryTree<Integer> arbol) {
		this.arbol = arbol;
	}
	
	// Recorrido en profundidad post-orden, porque necesito primero la suma de los subarboles.
	public BinaryTree<Integer> suma(){
		int sumaDerecha = 0;
		int sumaIzquierda = 0;
		if (this.arbol.isEmpty()) {
			return null;
		}
		
		if(this.arbol.hasRightChild()) {
			sumaDerecha += sumarSubArboles(this.arbol.getRightChild());
		}
		
		if(this.arbol.hasLeftChild()) {
			sumaIzquierda += sumarSubArboles(this.arbol.getLeftChild());
		}
		
		this.arbol.setData((sumaIzquierda+sumaDerecha));
		return this.arbol;
	}
	
	private int sumarSubArboles(BinaryTree<Integer> arbol) {
		int suma = 0;
		if (arbol.isLeaf()) {
			return 0;
		}
		
		if(arbol.hasLeftChild()) {
			suma += arbol.getData() + sumarSubArboles(arbol.getLeftChild());
		}
		
		if(arbol.hasRightChild()){
			suma += arbol.getData() + sumarSubArboles(arbol.getRightChild());
		}
		return suma;
	}

}