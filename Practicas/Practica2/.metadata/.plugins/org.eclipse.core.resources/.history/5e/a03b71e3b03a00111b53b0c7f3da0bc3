package ej1;

public class RedBinariaLlenaEj4 {

	/* a) Indique qué estrategia (recorrido en profundidad o por niveles) utilizará para resolver el
	problema
		Voy a usar recorrido en profundidad, en especifico con post-orden, ya que necesito las respuestas
		(los calculos de retardo) de los hijos para poder decidir cual es el maximo entre ellos.
	*/
	
	public int retardoReenvio(BinaryTree<Integer> arbol) {
		int max = 0;

		//caso base, llegué a una hoja
		if (arbol.isLeaf()) {
			return arbol.getData();
		}
		
		// Obtengo el máximo acumulado de cada rama (como es arbol binario lleno, sé que si no es hoja tiene ambos hijos)
	    int valorDerecho = retardoReenvio(arbol.getRightChild());
	    int valorIzquierdo = retardoReenvio(arbol.getLeftChild());
		
		if (valorDerecho > valorIzquierdo) {
			max = valorDerecho + arbol.getData();
		} else
			max = valorIzquierdo + arbol.getData();
	
		return max;
	}
	
	public static void main(String[]args) {
		BinaryTree<Integer> ab = new BinaryTree<>(10);
		BinaryTree<Integer> izquierdo = new BinaryTree<>(2);
		BinaryTree<Integer> derecho = new BinaryTree<>(3);
		
		izquierdo.addLeftChild(new BinaryTree<Integer>(5));
		izquierdo.addRightChild(new BinaryTree<Integer>(4));
		
		derecho.addLeftChild(new BinaryTree<Integer>(9));
		derecho.addRightChild(new BinaryTree<Integer>(8));
		
		ab.addLeftChild(izquierdo);
		ab.addRightChild(derecho);
		
		izquierdo.getLeftChild().addLeftChild(new BinaryTree<Integer>(7));
		izquierdo.getLeftChild().addRightChild(new BinaryTree<Integer>(8));
		izquierdo.getRightChild().addLeftChild(new BinaryTree<Integer>(5));
		izquierdo.getRightChild().addRightChild(new BinaryTree<Integer>(6));
		
		derecho.getLeftChild().addLeftChild(new BinaryTree<Integer>(12));
		derecho.getLeftChild().addRightChild();
	}
}
