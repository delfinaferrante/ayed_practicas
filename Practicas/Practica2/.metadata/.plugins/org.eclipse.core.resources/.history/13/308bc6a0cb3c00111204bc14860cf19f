package ej1;

public class ParcialArbolesEj7 {
	private BinaryTree<Integer> arbol;
	
	
	public boolean isLeftTree (int num) {
		if (this.arbol.isEmpty()) {
			return false;
		}
		return buscarYComparar(this.arbol, num);
	}
	
	private boolean buscarYComparar(BinaryTree<Integer> arbol, int num) {
		if (arbol == null) {
			return false;
		}
		
		// pregunto si encontre el arbol con dato 'num'
		if (arbol.getData() == num) {
			int cantIzq = contarNodos(arbol);
			int cantDer = contarNodos(arbol);
			return cantIzq > cantDer;
		}
		
		// si no lo encontré, sigo buscando
		boolean encontreEnIzquierda = false;
		if (arbol.hasLeftChild()) {
			encontreEnIzquierda = buscarYComparar(arbol.getLeftChild(), num);
		}
		
		if (encontreEnIzquierda) {
			return true;
		}
		
		// si no esta en la izquierda, busco a la derecha
		if (arbol.hasRightChild()) {
			return buscarYComparar(arbol.getRightChild(), num);
		}
		
		// si no lo encontre en ningun lado, no existe
		return false;
	}
	
	private int contarNodos(BinaryTree<Integer>arbol) {
		if(arbol == null) {
			return 0;
		}
		
		int cant = 0;
		
		if(arbol.hasLeftChild()) {
			contarNodos(arbol.getLeftChild());
		}
		
		if (arbol.hasRightChild()) {
			contarNodos(arbol.getRightChild());
		}
	}
}
